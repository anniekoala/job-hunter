{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Application status",
  "type": "object",
  "required": ["slug", "company", "role", "stage", "history"],
  "properties": {
    "slug": { "type": "string" },
    "company": { "type": "string" },
    "role": { "type": "string" },
    "link": { "type": "string" },
    "stage": {
      "type": "string",
      "enum": [
        "selected",
        "building",
        "materials-ready",
        "applied",
        "interview-invited",
        "interview-prep",
        "done",
        "rejected",
        "archived"
      ]
    },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "at"],
        "properties": {
          "stage": { "type": "string" },
          "at": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
